# Pulsemon - Environment Variables Examples... The values are not real.. It is just to know what the variables are.

#Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_database_user
DB_PASSWORD=your_password
DB_NAME=your_database_name

#App Setting
WORKER_POOL_SIZE=50
SERVER_PORT=8080
APP_ENV=development


JWT_SECRET=your_jwt_secret

RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=sub@domain.com

ALLOWED_ORIGINS= frontend url or any other url

# Admin Seeder
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme
ADMIN_USERNAME=admin

# BAse Url
APP_BASE_URL=frontendUrl